# --- Loom Core .gitignore ---
# Protect runtime memory: data/ contents are NOT committed, but the
# directory scaffold (.gitkeep) is preserved. See DECISIONS.md (DEC-001).
data/**
!data/
!data/**/
!data/**/.gitkeep

# Secrets
.env
.env.*
*.secret
secrets/
*.key
*.pem

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
